# Робастное обучение
# ==========================================

model_robust = FHNController(PARAMS)

optimizer_robust = torch.optim.Adam(model_robust.parameters(), lr=0.005)

info_robust = fit_random_starts(
    500, 
    model_robust, 
    optimizer_robust,
    target=target_state, 
    t_span=t, 
    val_s1=s1,
    center=torch.tensor([0.5, 0.0]), 
    radius=1.5,
)

traj_robust, u_robust, _ = run_inference(model_robust, s0, t)

plot_training(
    info_robust,
    traj_robust, 
    u_robust, 
    t_final,
    target_state.numpy(),
    s0.numpy()
)

