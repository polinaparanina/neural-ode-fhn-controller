# ==========================================
# Запуск с константным значением фона
# ==========================================

model = FHNController(PARAMS)

optimizer = torch.optim.Adam(model.parameters(), lr=0.005)

info = fit(500, model,optimizer, s0, s1, t, target_state)

traj_final, u_final, t_final = run_inference(model, s0, t)

plot_training(info, 
    traj_final, 
    u_final, 
    t_final, 
    target_state.numpy(), 
    s0.numpy()
)

# %%
# ==========================================
# Тест робастности к начальным условиям
# ==========================================

trajs_rand, dists_rand = test_random_starts(
    model, 
    target_state, 
    t,
    center=s0, 
    n_samples=15, 
    noise_std=0.5
)

print(f"Среднее расстояние до цели: {np.mean(dists_rand):.4f}")
print(f"Максимальное расстояние: {np.max(dists_rand):.4f}")

plot_robustness(
    trajs_rand, 
    target_state.numpy(), 
    np.mean(dists_rand)
)

# %%
# ==========================================
# Сравнение работы контроллера с шумом и без
# ==========================================

traj_noisy = run_inference_with_noise(
    model, 
    s0, 
    t, 
    sigma=0.02
)

plot_noise_comparison(
    traj_final, 
    traj_noisy, 
    target_state.numpy()
)

