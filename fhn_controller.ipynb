ou_func = make_ou_func(theta=0.1, mu=-0.35, sigma=0.05, dt=0.05)

traj_ou, u_ou, z_ou = run_inference_with_bg_func(model, s0, t, ou_func)

plot_bg_test(
    traj_ou, u_ou, z_ou,
    t.numpy(), target_state.numpy(),
    title='Стохастический фон: процесс Орнштейна-Уленбека'
)

