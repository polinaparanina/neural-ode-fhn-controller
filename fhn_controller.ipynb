class FHNController(nn.Module):
    
    """
    Нейросетевой контроллер для управления системой ФитцХью-Нагумо (FHN).

    Класс описывает динамику системы дифференциальных уравнений FHN,
    где управляющее воздействие генерируется встроенной нейронной сетью (MLP). Модель используется вместе с решателями ODE (например, torchdiffeq).

    
    Архитектура:
    -------
    Полносвязная сеть из 2 слоев. 
    Функция активации: Tanh(). 
    Выход масштабируется на max_current: u in [-max_current, max_current].
    
    Параметры сети:
    -------
    На вход:
        p : dict
            Словарь параметров модели: a, b, c, max_current, z_bg.
    На выходе: управляющее воздействие

    Методы:
    -------
    control(state, t):
        Вычисляет значение управляющего воздействия в данный момент времени.
    
    forward(t, state):
        Вычисляет производные состояния системы. 
        Вызывается автоматически внутри решателя odeint.
    """
    
    
    def __init__(self, p):
        super().__init__()
        
        self.a, self.b, self.c = p['a'], p['b'], p['c']
        self.max_current = p['max_current']
        self.z_bg = p['z_bg']                     
        
        self.net = nn.Sequential(
            nn.Linear(3, 32),
            nn.Tanh(),
            nn.Linear(32, 1),
            nn.Tanh(),
        )

    def control(self, state, t):
        """
        Вычисляет управляющее воздействие. 
        """
        
        inp = torch.cat([state, t.reshape(1)])
        u = self.net(inp) * self.max_current      
        return u

    def forward(self, t, state):
        """
        Вычисляет производные состояния системы. 
        """
        
        x, y = state[0], state[1]
        u = self.control(state, t)
        z_total = self.z_bg + u[0]                

        dx = self.c * (y + x - x**3/3 + z_total)
        dy = -(1/self.c) * (x - self.a + self.b * y)
        return torch.stack([dx, dy])

# %%
def loss_func(model, traj, t_span, target):
    '''
    Вычисляет функционал качества для задачи оптимального управления.
    
    L = w_p * MSE_final + w_e * E[u^2] + w_s * E[(u_{k+1} - u_k)^2],
    где:
        MSE_final - среднеквадратичное отклонение на последних 20% траектории
                    от целевого состояния (точность стабилизации);
        E[u^2]    - средняя квадратичная мощность управления (энергия);
        E[(delta u)^2] - среднеквадратичное изменение управления между шагами (гладкость).

    Веса: w_p = 1000, w_e = 0.05, w_s = 0.5.
    Доминирующий вес точности обеспечивает приоритет сходимости к цели.

    
    Args:
        model(nn.Model): Обучаемая модель. 
        traj (torch.Tensor): Траектория системы, полученная решателем ОДУ.
        t_span (torch.Tensor): Вектор моментов времени. 
        target (torch.Tensor): Целевое состояние, к которому должна прийти система.
       
    Returns:
        - loss (torch.Tensor): Суммарный лосс с градиентами.
        - precision (float): Значение точности (MSE). 
        
    '''
    
    final_states = traj[-20:]
    precision = torch.mean((final_states - target)**2)
    
    t = t_span.unsqueeze(1)
    inp = torch.cat([traj, t], dim=1)
    
    u = model.net(inp) * model.max_current
    u = u.squeeze()
    
    energy = torch.mean(u**2)
    smooth = torch.mean((u[1:] - u[:-1])**2)
    
    loss = 1000 * precision + 0.05 * energy + 0.5 * smooth
    
    return loss, precision.item()

# %%
def train_one_epoch(model, optimizer, s0, t_span, target):
    '''
    Выполняет одну итерацию (эпоху) обучения контроллера через симуляцию ODE.
    
    Args:
        model (nn.Module): Нейросетевой контроллер. 
        optimizer (torch.optim.Optimizer): Оптимизатор, Adam. 
        s0 (torch.Tensor): Начальное состояние системы [x0, y0].
        t_span (torch.Tensor): Вектор моментов времени. 
        target (torch.Tensor): Целевое состояние, к которому должна прийти система.

    Returns:
        - loss: Значение функции потерь
        - prec: Точность (MSE) достижения цели.
    '''
    
    model.train()
    optimizer.zero_grad()
    
    traj = odeint(model, s0, t_span, method='rk4')
    
    loss, prec = loss_func(model, traj, t_span, target)
    
    loss.backward()
    optimizer.step()
    
    return loss.item(), prec

# %%
def train_one_epoch_random_start(
    model, 
    optimizer, 
    target, 
    t_span, 
    center: torch.Tensor = torch.tensor([0.5, 0.0]), 
    radius: float = 1.5
    ):
    
    """
    Одна эпоха обучения со случайным начальным состоянием.

    На каждой эпохе начальное состояние s0 сэмплируется равномерно
    из квадрата [-radius, radius]^2 вокруг точки center:
        s0 = center + U(-1, 1)^2 * radius

    Args:
    model : FHNController
    optimizer : torch.optim.Optimizer
    target : Tensor, shape (2,)
    t_span : Tensor, shape (T,)
    center : Tensor, shape (2,) - центр области начальных условий
    radius : float - радиус области

    Returns:
        - loss: Значение функции потерь
        - prec: Точность (MSE) достижения цели.
    """
    
    model.train()
    optimizer.zero_grad()

    s0_rand = center + (torch.rand(2) * 2 - 1) * radius
    traj = odeint(model, s0_rand, t_span, method="rk4")
    loss, prec = loss_func(model, traj, t_span, target)

    loss.backward()
    optimizer.step()

    return loss.item(), prec

# %%
def validate(model, s1, t_span, target):
    '''
    Оценивает работу контроллера на инференсе.
    
    Args:
        model (nn.Module): Нейросетевой контроллер. 
        s1 (torch.Tensor): Валидационная начальная точка [x_val, y_val].
        t_span (torch.Tensor): Вектор моментов времени. 
        target (torch.Tensor): Целевое состояние, к которому должна прийти система.
       
    Returns:
        - loss: Значение функции потерь
        - prec: Точность (MSE) достижения цели. 
    '''
    
    model.eval()
    
    with torch.no_grad():
        traj = odeint(model, s1, t_span, method='rk4')
        loss, prec = loss_func(model, traj, t_span, target)
    
    return loss.item(), prec

# %%
def fit(epochs, model, optimizer, s0, s1, t_span, target):
    '''
    Основной тренировочный цикл, объединяющий обучение и валидацию.
    
    Args:
        epochs (int): Общее количество итераций обучения.
        model (nn.Module): Нейросетевой контроллер.
        optimizer (torch.optim.Optimizer): Алгоритм оптимизации весов.
        s0 (torch.Tensor): Начальное состояние для обучения. 
        s1 (torch.Tensor): Начальное состояние для валидации. 
        t_span (torch.Tensor): Вектор моментов времени. 
        target (torch.Tensor): Целевое состояние, к которому должна прийти система.

    Returns:
        dict: Словарь `history`, содержащий списки:
            - 'train_loss': динамика общей ошибки на обучении.
            - 'val_loss': динамика общей ошибки на валидации.
            - 'train_prec': точность на обучении.
            - 'val_prec': точность на валидации.
    '''
    
    history = {'train_loss': [], 'val_loss': [], 'train_prec': [], 'val_prec': []}
    
    for epoch in tqdm(range(epochs)):
        train_loss, train_prec = train_one_epoch(model, optimizer, s0, t_span, target)
        
        val_loss, val_prec = validate(model, s1, t_span, target)
        
        history['train_loss'].append(train_loss)
        history['train_prec'].append(train_prec)
        history['val_loss'].append(val_loss)
        history['val_prec'].append(val_prec)
        
    return history

# %%
def fit_random_starts(epochs, model, optimizer, target, t_span, val_s1, center, radius):
    """
    Цикл обучения со случайными начальными условиями
    
    Args:
        epochs (int): Общее количество итераций обучения.
        model (nn.Module): Нейросетевой контроллер.
        optimizer (torch.optim.Optimizer): Алгоритм оптимизации весов.
        target (torch.Tensor): Целевое состояние, к которому должна прийти система.
        t_span (torch.Tensor): Вектор моментов времени. 
        val_s1 (torch.Tensor): Начальное состояние для валидации. 
        center (torch.Tensor): Центр области начальных условий
        radius (float): Радиус области
        

    Returns:
        dict: Словарь `history`, содержащий списки:
            - 'train_loss': динамика общей ошибки на обучении.
            - 'val_loss': динамика общей ошибки на валидации.
            - 'train_prec': точность на обучении.
            - 'val_prec': точность на валидации.
    """
    
    history = {"train_loss": [], "val_loss": [], "train_prec": [], "val_prec": []}

    for epoch in tqdm(range(epochs)):
        train_loss, train_prec = train_one_epoch_random_start(
            model, optimizer, target, t_span, center, radius
        )
        val_loss, val_prec = validate(model, val_s1, t_span, target)

        history["train_loss"].append(train_loss)
        history["val_loss"].append(val_loss)
        history["train_prec"].append(train_prec)
        history["val_prec"].append(val_prec)

    return history

# %%
def run_inference(model, s0, t_span):
    '''
    Генерирует финальные данные траектории и управления для анализа.
    
    Args:
        model (nn.Module): Нейросетевой контроллер.
        s0 (torch.Tensor): Начальное состояние для обучения. 
        t_span (torch.Tensor): Вектор моментов времени. 

    Returns:
        tuple:
            - traj(np.ndarray): Массив состояний [steps, 2].
            - u (np.ndarray): Массив сигналов управления [steps].
            - t_np (np.ndarray): Массив моментов времени [steps].
    '''
    
    model.eval()
    
    with torch.no_grad():
        traj = odeint(model, s0, t_span, method='rk4')
        t_grid = t_span.unsqueeze(1)
        u = model.net(torch.cat([traj, t_grid], dim=1)) * model.max_current
        
    return traj.numpy(), u.numpy(), t_span.numpy()

# %%
def test_random_starts(model, target, t_span, center, n_samples=20, noise_std=0.5):
    """
    Проверка робастности к начальным условиям.

    Модель запускается из n_samples точек, сэмплированных вокруг центра:
        s0_i = center + N(0, noise_std^2) * I_2

    Для каждой траектории вычисляется финальное расстояние до цели

    Args:
        model(nn.Module) : FHNController
        target(torch.Tensor)
        t_span(torch.Tensor)
        center(torch.Tensor) - центр облака начальных точек
        n_samples(int) - количество запусков
        noise_std(float) - стандартное отклонение смещения начального состояния

    Returns:
        trajectories(np.ndarray): Массив состояний
        final_distances : Массив расстояний до цели
    """
    
    model.eval()
    trajectories     = []
    final_distances  = []

    with torch.no_grad():
        for _ in range(n_samples):
            s0_noisy = center + torch.randn(2) * noise_std
            traj = odeint(model, s0_noisy, t_span, method="rk4")
            trajectories.append(traj.numpy())
            final_distances.append(torch.norm(traj[-1] - target).item())

    return trajectories, final_distances

# %%
def run_inference_with_noise(model, s0, t_span, sigma=0.02):
    """
    Моделирует систему с аддитивным белым шумом:
        s_{k+1} = s_k + h * f(s_k, t_k) + sigma * sqrt(h) * xi_k
    где 
    xi_k ~ N(0, I_2) - стандартный гауссовский шум,
    h - шаг интегрирования, 
    f - правая часть замкнутой системы.

    Используется для оценки устойчивости контроллера к непрерывным малым возмущениям состояния

    Params:
    model(nn.Module) : FHNController
    s0 (torch.Tensor)
    t_span(torch.Tensor)
    sigma(float) - интенсивность шума (стандартное отклонение на шаг sqrt(h))

    Returns:
    ----------
    traj(np.ndarray): Массив состояний
    """
    
    model.eval()
    dt    = t_span[1] - t_span[0]
    state = s0.clone()
    traj  = [s0.numpy()]

    with torch.no_grad():
        for i in range(1, len(t_span)):
            t_step = t_span[i - 1].unsqueeze(0)
            dstate = model(t_step, state)
            noise  = torch.randn(2) * sigma * torch.sqrt(dt)
            state  = state + dt * dstate + noise
            traj.append(state.numpy())

    return np.array(traj)

# %%
# ==========================================
# Переменный фоновый стимул
# ==========================================

Z_BG_MIN, Z_BG_MAX = -0.5, -0.2

def clamp_z(z: float) -> float:
    """
    Ограничение z_bg в допустимом диапазоне [Z_BG_MIN, Z_BG_MAX].
    """
    return max(Z_BG_MIN, min(Z_BG_MAX, z))


def make_ou_func(theta: float = 0.1, mu: float = -0.35,
                 sigma: float = 0.05, dt: float = 0.05):
    """
    Процесс Орнштейна-Уленбека:
        z_{k+1} = z_k + theta*(mu - z_k)*dt + sigma*sqrt(dt)*xi_k, xi_k ~ N(0,1)

    При выходе за границы применяется отражение.
    Моделирует нейронный шум - случайный, но стационарный фоновый стимул.

    Params:
        theta: скорость возврата к среднему
        mu: среднее значение процесса
        sigma: интенсивность флуктуаций
        dt: шаг дискретизации
    """
    
    z = mu
    
    def ou(t: float) -> float:
        nonlocal z
        z += theta * (mu - z) * dt + sigma * np.sqrt(dt) * np.random.randn()
        if z < Z_BG_MIN:
            z = 2 * Z_BG_MIN - z
        elif z > Z_BG_MAX:
            z = 2 * Z_BG_MAX - z
        return z
    
    return ou


def make_pulse_func(background: float = -0.4, amplitude: float = 0.2,
                    start: float = 5.0, duration: float = 2.0):
    """
    Моделирует одиночный патологический разряд.
    """
    
    def pulse(t: float) -> float:
        val = background + amplitude if start <= t <= start + duration else background
        return clamp_z(val)
    
    return pulse

# %%
class BaseFHN(nn.Module):
    """
    Базовый класс для всех стратегий управления.
    Реализует динамику с переменным фоном z_bg_func(t).
    Закон управления задаётся методом get_control в подклассах.
    """
    
    def __init__(self, p: dict, z_bg_func=None):
        super().__init__()
        self.a = p["a"]; self.b = p["b"]; self.c = p["c"]
        self.max_current = p["max_current"]
        self.z_bg = p.get("z_bg", 0.0)
        self.z_bg_func = z_bg_func if z_bg_func is not None else (lambda t: self.z_bg)

    def get_control(self, state, t):
        raise NotImplementedError

    def forward(self, t, state):
        x, y = state[0], state[1]
        u = self.get_control(state, t)
        u_val = u if isinstance(u, torch.Tensor) else torch.tensor(u, dtype=torch.float32)
        t_val = t.item() if isinstance(t, torch.Tensor) else t
        
        z_total = float(self.z_bg_func(t_val)) + u_val
        
        dx = self.c * (y + x - x**3 / 3 + z_total)
        dy = -(1.0 / self.c) * (x - self.a + self.b * y)
        
        return torch.stack([dx, dy])
    

class NoControl(BaseFHN):
    """
    Система без управления: u(t) = 0.
    """
    
    def get_control(self, state, t):
        return torch.tensor(0.0)
    

class LinearFeedback(BaseFHN):
    """
    П-регулятор: u(t) = -k1*(x - x*) - k2*(y - y*).

    Params:
    target(torch.Tensor)
    k1, k2: коэффициенты усиления
    """
    
    def __init__(self, p, target, k1=1.0, k2=1.0, z_bg_func=None):
        super().__init__(p, z_bg_func=z_bg_func)
        self.target = target; self.k1 = k1; self.k2 = k2

    def get_control(self, state, t):
        x, y = state[0], state[1]
        return -self.k1 * (x - self.target[0]) - self.k2 * (y - self.target[1])
    

class NeuralControllerAdapter(BaseFHN):
    """
    Адаптер обученного FHNController. 
    Позволяет подменять z_bg_func без еще одного запуска.
    """
    def __init__(self, trained_model: "FHNController", z_bg_func=None):
        super().__init__({
            "a": trained_model.a, 
            "b": trained_model.b, 
            "c": trained_model.c,
            "max_current": trained_model.max_current, 
            "z_bg": trained_model.z_bg,
        }, 
        z_bg_func=z_bg_func)
        
        self.model = trained_model

    def get_control(self, state, t):
        return self.model.control(state, t)[0]

# %%
def run_inference_with_bg_func(model, s0, t_span, bg_func):
    """
    Запуск обученного контроллера с переменным фоновым стимулом.

    Params:
        model: обученный FHNController
        s0: начальное состояние
        t_span: временная сетка
        bg_func: функция z_bg(t)

    Returns:
        traj (np.ndarray): траектория состояний
        u_hist (np.ndarray): управляющий сигнал
        z_hist (np.ndarray): реализация фонового стимула
    """
    
    model.eval()
    dt = t_span[1] - t_span[0]
    state = s0.clone()
    traj, u_hist, z_hist = [s0.numpy()], [], []

    with torch.no_grad():
        for i in range(1, len(t_span)):
            t_step = t_span[i - 1].unsqueeze(0)
            t_val  = t_span[i - 1].item()

            u = model.control(state, t_step)
            u_val = u[0].item()

            z_bg_now = bg_func(t_val)
            z_total  = z_bg_now + u_val

            x, y = state[0], state[1]
            dx = model.c * (y + x - x**3 / 3 + z_total)
            dy = -(1.0 / model.c) * (x - model.a + model.b * y)

            state = state + dt * torch.stack([dx, dy])
            traj.append(state.numpy())
            u_hist.append(u_val)
            z_hist.append(z_bg_now)

    return np.array(traj), np.array(u_hist), np.array(z_hist)

# %%
def plot_training(history, traj, u, t, target, s0_point):
    
    """
    График отображает: историю функции потерь, историю MSE, временные зависимости x(t) и y(t), фазовый портрет, управляющий сигнал u(t).
    """
    
    fig = plt.figure(figsize=(8, 15))
    
    # 1. История Loss
    ax1 = plt.subplot(5, 1, 1)
    ax1.plot(history['train_loss'], label='Обучающая выборка')
    ax1.plot(history['val_loss'], label='Валидационная выборка', linestyle='--')
    ax1.set_title('История функции потерь')
    ax1.set_yscale('log')
    ax1.legend()

    # 2. История Precision
    ax2 = plt.subplot(5, 1, 2)
    ax2.plot(history['train_prec'], label='Обучающая выборка')
    ax2.plot(history['val_prec'], label='Валидационная выборка', color='green')
    ax2.set_title('История ошибки (MSE)')
    ax2.set_yscale('log')
    ax2.legend()

    # 3. Траектория x(t) и y(t)
    ax3 = plt.subplot(5, 1, 3)
    ax3.plot(t, traj[:, 0], label='x (мембранный потенциал)', color='royalblue')
    ax3.plot(t, traj[:, 1], label='y (переменная восстановления)', color='darkorange')
    ax3.axhline(target[0], color='blue', linestyle=':', alpha=0.5)
    ax3.axhline(target[1], color='orange', linestyle=':', alpha=0.5)
    ax3.set_title('График состояния')
    ax3.legend()

    # 4. Фазовый портрет
    ax4 = plt.subplot(5, 1, 4)
    ax4.plot(traj[:, 0], traj[:, 1], color='purple')
    ax4.scatter(s0_point[0], s0_point[1], color='red', label='Начальное состояние')
    ax4.scatter(target[0], target[1], marker='*', s=100, color='gold', label='Целевое состояние')
    ax4.set_title('Фазовый портрет')
    ax4.set_xlabel('x')
    ax4.set_ylabel('y')
    ax4.legend()

    # 5. Управление z(t)
    ax5 = plt.subplot(5, 1, 5)
    ax5.plot(t, u, color='crimson')
    ax5.axhline(PARAMS['max_current'], color='black', linestyle='--', alpha=0.3)
    ax5.axhline(-PARAMS['max_current'], color='black', linestyle='--', alpha=0.3)
    ax5.set_title('Управляющее воздействие')
    ax5.set_xlabel('t')

    plt.tight_layout()
    plt.show()
    

def plot_robustness(trajectories, target, mean_dist):
    
    """
    График робастности к начальным условиям.
    """
    
    plt.figure(figsize=(7, 7))
    
    for traj in trajectories:
        plt.plot(traj[:, 0], traj[:, 1], alpha=0.5, lw=0.8)
        
    plt.scatter(*target, c="red", marker="*", s=200, label="Целевое состояние")
    plt.xlabel("x")
    plt.ylabel("y")
    plt.title(f"Робастность к начальным условиям\nСреднее финальное расстояние = {mean_dist:.3f}")
    plt.legend(); 
    plt.show()
    
    

def plot_noise_comparison(traj_det, traj_noisy, target):
    """
    Сравнение детерминированной и зашумлённой траекторий.
    """
    
    plt.figure(figsize=(6, 5))
    
    plt.plot(traj_det[:, 0],   traj_det[:, 1],   label="Детерминированная", lw=1.5)
    plt.plot(traj_noisy[:, 0], traj_noisy[:, 1], label="С шумом 0.02", alpha=0.8, lw=0.8)
    plt.scatter(*target, c="red", marker="*", s=150, label="Целевое состояние")
    plt.xlabel("x") 
    plt.ylabel("y")
    plt.title("Устойчивость к непрерывным возмущениям")
    plt.legend(); 
    plt.show()
    
    

def plot_bg_test(traj, u_hist, z_hist, t_np, target, title):
    """
    График результата при переменном фоновом стимуле.
    """
    
    fig, axes = plt.subplots(4, 1, figsize=(9, 14), sharex=True)

    axes[0].plot(t_np, traj[:, 0], color='royalblue')
    axes[0].axhline(target[0], color='blue', linestyle='--', alpha=0.5, label='x*')
    axes[0].set_ylabel('x'); 
    axes[0].set_title('Мембранный потенциал x(t)')
    axes[0].legend()

    axes[1].plot(t_np, traj[:, 1], color='darkorange')
    axes[1].axhline(target[1], color='orange', linestyle='--', alpha=0.5, label='y*')
    axes[1].set_ylabel('y'); 
    axes[1].set_title('Переменная восстановления y(t)')
    axes[1].legend()

    axes[2].plot(t_np[1:], u_hist, color='crimson')
    axes[2].axhline(0, color='black', linestyle='--', alpha=0.3)
    axes[2].set_ylabel('u'); 
    axes[2].set_title('Управляющее воздействие u(t)')

    axes[3].plot(t_np[1:], z_hist, color='gray')
    axes[3].set_ylabel('z_bg'); 
    axes[3].set_title('Фоновый стимул z_bg(t)')
    axes[3].set_xlabel('t')

    plt.suptitle(title, fontsize=15)
    plt.tight_layout()
    plt.show()

